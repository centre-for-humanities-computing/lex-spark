# Your HuggingFace token (needed for Gemma - gated model)
HF_TOKEN=hf_your_token_here

# Paths
MODEL_CACHE_PATH=./models

# Model IDs - UPDATE THESE to exact HuggingFace slugs
GEMMA_LARGE_MODEL=bg-digitalservices/Gemma-4-26B-A4B-it-NVFP4A16
GEMMA_EXTRA_SMALL_MODEL=google/gemma-4-E2B-it
EMBED_MODEL_1=intfloat/multilingual-e5-large
EMBED_MODEL_2=jinaai/jina-embeddings-v5-text-small-retrieval

# ── Benchmark configs ────────────────────────────────────────────────
# Config 1 — Community NVFP4 (W4A4), no speculative decoding
C1_GEMMA_26B=bg-digitalservices/Gemma-4-26B-A4B-it-NVFP4
C1_GEMMA_E2B=bg-digitalservices/Gemma-4-E2B-it-NVFP4

# Config 2 — MTP speculative decoding (NVIDIA NVFP4 target + Google assistants)
C2_GEMMA_26B=nvidia/Gemma-4-26B-A4B-NVFP4
C2_GEMMA_26B_ASSISTANT=google/gemma-4-26B-A4B-it-assistant
C2_GEMMA_E2B=google/gemma-4-E2B-it-qat-w4a16-ct
C2_GEMMA_E2B_ASSISTANT=google/gemma-4-E2B-it-qat-q4_0-unquantized-assistant

# Config 3 — DFlash (26B) + PARO (E2B) — requires custom images
C3_GEMMA_26B=google/gemma-4-26B-A4B-it
C3_GEMMA_26B_DFLASH=z-lab/gemma-4-26B-A4B-it-DFlash
C3_GEMMA_E2B=z-lab/gemma-4-E2B-it-PARO

# Config 4 — DiffusionGemma (26B) + QAT compressed-tensors (E2B)
C4_GEMMA_26B=nvidia/diffusiongemma-26B-A4B-it-NVFP4
C4_GEMMA_E2B=google/gemma-4-E2B-it-qat-w4a16-ct