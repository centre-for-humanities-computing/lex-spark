# Your HuggingFace token (needed for Gemma - gated model)
HF_TOKEN=hf_your_token_here

# Paths
MODEL_CACHE_PATH=./models

# Model IDs - UPDATE THESE to exact HuggingFace slugs
GEMMA_LARGE_MODEL=bg-digitalservices/Gemma-4-26B-A4B-it-NVFP4A16
GEMMA_EXTRA_SMALL_MODEL=google/gemma-4-E2B-it
EMBED_MODEL_1=intfloat/multilingual-e5-large
EMBED_MODEL_2=jinaai/jina-embeddings-v5-text-small-retrieval

# ── Experimental stack (docker-compose.experimental.yml) ──────
# DiffusionGemma 26B (commented out — kept for future experimentation)
# GEMMA_DIFFUSION_MODEL=nvidia/diffusiongemma-26B-A4B-it-NVFP4
# NVFP4 26B MoE (NVIDIA quantized + standard assistant for MTP)
GEMMA_26B_NVFP4_MODEL=nvidia/Gemma-4-26B-A4B-NVFP4
GEMMA_26B_ASSISTANT_MODEL=google/gemma-4-26B-A4B-it-assistant
# QAT E2B (w4a16 compressed-tensors + MTP assistant)
GEMMA_E2B_QUANT_MODEL=google/gemma-4-E2B-it-qat-w4a16-ct
GEMMA_E2B_ASSISTANT_MODEL=google/gemma-4-E2B-it-qat-q4_0-unquantized-assistant